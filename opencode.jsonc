{
  "$schema": "https://opencode.ai/config.json",

  "lsp": true,

  "permission": {
    "*": "ask",
    "external_directory": "deny",
    "webfetch": "ask",
    "websearch": "ask",
    "bash": {
      "*": "ask",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "find *": "allow",
      "ls *": "allow",
      "go test*": "allow",
      "go fmt*": "allow",
      "go vet*": "allow",
      "rm -rf *": "deny",
      "git push*": "deny",
      "ssh *": "deny",
      "scp *": "deny"
    }
  },

  "agent": {
    "qindu-orchestrator": {
      "description": "Pilote le cycle Agile Qindu et orchestre DPO, CISO, DevSecOps, QA et Release.",
      "mode": "primary",
      "temperature": 0.1,
      "steps": 40,
      "permission": {
        "edit": {
          "*": "deny",
          "docs/implementation/**": "allow",
          "ARCHITECTURE.md": "allow",
          "AGENTS.md": "allow",
          "README.md": "allow",
          "CONTRIBUTING.md": "allow",
          "LICENSE": "allow",
          "docs/decisions/**": "allow"
        },
        "bash": {
          "*": "ask",
          "git status*": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "grep *": "allow",
          "rg *": "allow",
          "find *": "allow",
          "ls *": "allow"
        },
        "task": {
          "*": "deny",
          "qindu-dpo": "allow",
          "qindu-ciso": "allow",
          "qindu-devsecops": "allow",
          "qindu-qa": "allow",
          "qindu-release": "allow"
        }
      }
    }
  }
}
