{
  "$schema": "https://opencode.ai/config.json",

  "lsp": true,

  "permission": {
    "*": "ask",
    "external_directory": "deny",
    "webfetch": "ask",
    "websearch": "ask",
    "bash": {
      "*": "ask",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "find *": "allow",
      "ls *": "allow",
      "go test*": "allow",
      "go fmt*": "allow",
      "go vet*": "allow",
      "rm -rf *": "deny",
      "git push*": "deny",
      "ssh *": "deny",
      "scp *": "deny"
    }
  },

  "agent": {
    "qindu-orchestrator": {
      "description": "Document router & clerk for the Qindu project. Routes artifacts between agents, writes story.md and closure.md, negotiates with reviewers using cross-sprint context only. Never reads source code. Cannot override reviewer verdicts. Uses grill-me at sprint start.",
      "mode": "primary",
      "temperature": 0.1,
      "steps": 40,
      "permission": {
        "edit": {
          "*": "deny",
          "docs/implementation/**": "allow",
          "ARCHITECTURE.md": "allow",
          "AGENTS.md": "allow",
          "README.md": "allow",
          "CONTRIBUTING.md": "allow",
          "LICENSE": "allow",
          "docs/decisions/**": "allow",
          "opencode.jsonc" : "ask"
        },
        "bash": {
          "*": "ask",
          "git status*": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "grep *": "allow",
          "rg *": "allow",
          "find *": "allow",
          "ls *": "allow"
        },
        "task": {
          "*": "deny",
          "qindu-dpo": "allow",
          "qindu-ciso": "allow",
          "qindu-devsecops": "allow",
          "qindu-qa": "allow",
          "qindu-release": "allow",
          "qindu-peer-reviewer": "allow",
          "qindu-qemu-tester": "allow"
        }
      }
    },
    "qindu-peer-reviewer": {
      "description": "Senior Go dev : revue de code impitoyable contre Clean Code, SOLID, Go Proverbs, Pragmatic Programmer. Note la maintenabilité et détecte les bugs.",
      "mode": "subagent",
      "temperature": 0.1
    },
    "qindu-qemu-tester": {
      "description": "Valide Qindu end-to-end: VM Windows QEMU (install, désinstall, service, proxy, TLS, PAC) + API integration (prompts réels, tokenisation, vault, réhydratation, logs).",
      "mode": "subagent",
      "temperature": 0.1
    }
  }
}
