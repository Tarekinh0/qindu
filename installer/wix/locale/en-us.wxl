<?xml version="1.0" encoding="utf-8"?>
<WixLocalization Culture="en-us" xmlns="http://schemas.microsoft.com/wix/2006/localization">
  <String Id="ProductName" Overridable="yes">Qindu AI Privacy Proxy</String>
  <String Id="Manufacturer" Overridable="yes">Qindu</String>
  <String Id="ProductDescription" Overridable="yes">Local privacy proxy that protects personal data in your AI conversations. All processing is local — nothing leaves your machine.</String>
  <String Id="FeatureTitle" Overridable="yes">Qindu Agent</String>
  <String Id="FeatureDesc" Overridable="yes">Installs the Qindu AI Privacy Proxy service and supporting files.</String>
  <String Id="ServiceName" Overridable="yes">QinduAgent</String>
  <String Id="ServiceDisplayName" Overridable="yes">Qindu AI Privacy Proxy</String>
  <String Id="ServiceDescription" Overridable="yes">Local TLS proxy that intercepts AI traffic for PII protection. Runs on loopback only.</String>
  <String Id="CAName" Overridable="yes">Qindu AI Privacy CA</String>
  <String Id="NoticeTitle" Overridable="yes">Important Privacy Information</String>
  <String Id="NoticeText" Overridable="yes">Qindu is a local privacy proxy that protects personal data in your AI conversations.\n\nQindu will:\n• Install a local Certificate Authority (CA) to inspect TLS traffic on AI service domains (e.g., chatgpt.com, claude.ai)\n• Write machine-wide browser policies for Chrome and Edge to route AI traffic through Qindu\n• Configure Windows Firewall rules to ensure traffic stays on your machine\n• Run as a background service under a restricted account\n\nWhat Qindu does NOT do:\n• Qindu does NOT collect, transmit, or store your AI conversations — all processing is local\n• No data is sent to Qindu as an organization. There is no telemetry, no tracking, and no user account.\n• The CA private key is stored only on your machine (DPAPI-encrypted) and never shared\n\nBrowser policies are machine-wide: all user accounts on this computer will have their AI traffic routed through Qindu.\n\nYou can uninstall Qindu at any time. During uninstallation, you can choose to delete all Qindu data.\n\nBy proceeding, you acknowledge that you understand and accept these terms.</String>
  <String Id="UnsafeCATitle" Overridable="yes">Advanced: CA Domain Restrictions</String>
  <String Id="UnsafeCAText" Overridable="yes">By default, the Qindu CA is restricted to AI provider domains only (chatgpt.com, claude.ai).\n\nCheck the box below ONLY if your browser does not support CA Name Constraints. This will generate a CA that can intercept ANY website — not just AI services — which reduces your security.</String>
  <String Id="UnsafeCACheckbox" Overridable="yes">Skip domain restrictions (reduces security — the CA will be able to intercept ANY website, not just AI services)</String>
  <String Id="DeleteDataTitle" Overridable="yes">Uninstall: Data Removal Options</String>
  <String Id="DeleteDataText" Overridable="yes">Qindu stores its data (CA key, vault, logs, configuration) in a local data directory.\n\nDo you want to delete all Qindu data?\n\nIf you plan to reinstall Qindu later, you may want to keep this data to preserve your settings.</String>
  <String Id="DeleteDataCheckbox" Overridable="yes">Delete all Qindu data (vault, logs, and configuration)</String>
  <String Id="UnsafeCASilentBlocked" Overridable="yes">Unsafe CA mode requires interactive installation. Please run the installer normally (not in silent/quiet mode) or uncheck the unsafe CA option.</String>
</WixLocalization>
