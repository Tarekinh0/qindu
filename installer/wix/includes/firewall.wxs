<?xml version="1.0" encoding="utf-8"?>
<Include xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Fragment>
    <!-- =============================================================
    Firewall rules — WixQuietExec pattern (PR-001)

    Rule names are hardcoded in English for uninstall consistency (PR-H5).
    The netsh commands have no MSI property references but are migrated to
    WixQuietExec for consistent error handling, MSI logging, and correct
    quoting of rule names containing spaces.
    ============================================================= -->

    <!-- FirewallAllowLoopback: allow loopback on port 8787 -->
    <SetProperty Id="FirewallAllowLoopback" Before="FirewallAllowLoopback" Sequence="execute"
        Value="&quot;netsh&quot; advfirewall firewall add rule name=&quot;Qindu Agent (Allow Loopback)&quot; dir=in action=allow remoteip=127.0.0.1 localport=8787 protocol=TCP">
        NOT Installed
    </SetProperty>
    <CustomAction
      Id="FirewallAllowLoopback"
      BinaryKey="WixCA"
      DllEntry="WixQuietExec64"
      Execute="deferred"
      Impersonate="no" Return="check" />

    <!-- FirewallBlockExternal: block external connections to port 8787 -->
    <SetProperty Id="FirewallBlockExternal" Before="FirewallBlockExternal" Sequence="execute"
        Value="&quot;netsh&quot; advfirewall firewall add rule name=&quot;Qindu Agent (Block External)&quot; dir=in action=block remoteip=any localport=8787 protocol=TCP">
        NOT Installed
    </SetProperty>
    <CustomAction
      Id="FirewallBlockExternal"
      BinaryKey="WixCA"
      DllEntry="WixQuietExec64"
      Execute="deferred"
      Impersonate="no" Return="check" />

    <!-- FirewallRemoveAllowLoopback: remove loopback allow rule on uninstall -->
    <SetProperty Id="FirewallRemoveAllowLoopback" Before="FirewallRemoveAllowLoopback" Sequence="execute"
        Value="&quot;netsh&quot; advfirewall firewall delete rule name=&quot;Qindu Agent (Allow Loopback)&quot;">
        Installed AND NOT REINSTALL
    </SetProperty>
    <CustomAction
      Id="FirewallRemoveAllowLoopback"
      BinaryKey="WixCA"
      DllEntry="WixQuietExec64"
      Execute="deferred"
      Impersonate="no" Return="check" />

    <!-- FirewallRemoveBlockExternal: remove block external rule on uninstall -->
    <SetProperty Id="FirewallRemoveBlockExternal" Before="FirewallRemoveBlockExternal" Sequence="execute"
        Value="&quot;netsh&quot; advfirewall firewall delete rule name=&quot;Qindu Agent (Block External)&quot;">
        Installed AND NOT REINSTALL
    </SetProperty>
    <CustomAction
      Id="FirewallRemoveBlockExternal"
      BinaryKey="WixCA"
      DllEntry="WixQuietExec64"
      Execute="deferred"
      Impersonate="no" Return="check" />

    <!-- FirewallRollbackAllowLoopback: rollback hook for loopback allow rule -->
    <SetProperty Id="FirewallRollbackAllowLoopback" Before="FirewallAllowLoopback" Sequence="execute"
        Value="&quot;netsh&quot; advfirewall firewall delete rule name=&quot;Qindu Agent (Allow Loopback)&quot;">
        NOT Installed
    </SetProperty>
    <CustomAction
      Id="FirewallRollbackAllowLoopback"
      BinaryKey="WixCA"
      DllEntry="WixQuietExec64"
      Execute="rollback"
      Impersonate="no" Return="ignore" />

    <!-- FirewallRollbackBlockExternal: rollback hook for block external rule -->
    <SetProperty Id="FirewallRollbackBlockExternal" Before="FirewallBlockExternal" Sequence="execute"
        Value="&quot;netsh&quot; advfirewall firewall delete rule name=&quot;Qindu Agent (Block External)&quot;">
        NOT Installed
    </SetProperty>
    <CustomAction
      Id="FirewallRollbackBlockExternal"
      BinaryKey="WixCA"
      DllEntry="WixQuietExec64"
      Execute="rollback"
      Impersonate="no" Return="ignore" />
  </Fragment>

</Include>
