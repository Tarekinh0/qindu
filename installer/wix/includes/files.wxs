<?xml version="1.0" encoding="utf-8"?>
<Include xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Fragment>
    <!-- Agent binary and service (INSTALLDIR = %PROGRAMFILES%\Qindu\) -->
    <DirectoryRef Id="INSTALLDIR">
      <Component Id="AgentExeComponent" Guid="*" Win64="yes">
        <File Id="AgentExe" Name="agent.exe" Source="qindu-agent.exe" KeyPath="yes" />
        <ServiceInstall
          Id="QinduServiceInstall"
          Name="!(loc.ServiceName)"
          DisplayName="!(loc.ServiceDisplayName)"
          Description="!(loc.ServiceDescription)"
          Type="ownProcess"
          Start="auto"
          Account="NT AUTHORITY\LocalService"
          ErrorControl="normal"
          Vital="yes" />
        <ServiceControl
          Id="QinduServiceControl"
          Name="!(loc.ServiceName)"
          Start="install"
          Stop="both"
          Remove="uninstall"
          Wait="yes" />
      </Component>
    </DirectoryRef>

    <!-- Default config (ConfigsDir = %PROGRAMFILES%\Qindu\configs\) -->
    <DirectoryRef Id="ConfigsDir">
      <Component Id="DefaultConfigComponent" Guid="*" Win64="yes">
        <File Id="DefaultConfig" Name="default.yaml" Source="configs\default.yaml" KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <!-- ProgramData directory with restricted ACL (SR-INSTALLER-8, DPO R6) -->
    <DirectoryRef Id="PROGRAMDATADIR">
      <Component Id="ProgramDataDirComponent" Guid="{C18EFC3C-DEBA-49E8-94D3-CFE10EA04BB2}" Win64="yes">
        <CreateFolder>
          <!-- SYSTEM: Full Control -->
          <Permission User="NT AUTHORITY\SYSTEM" GenericAll="yes" />
          <!-- Administrators: Full Control -->
          <Permission User="BUILTIN\Administrators" GenericAll="yes" />
          <!-- LocalService: Read/Write (service account) -->
          <Permission User="NT AUTHORITY\LocalService" GenericRead="yes" GenericWrite="yes" GenericExecute="yes" />
        </CreateFolder>
      </Component>
    </DirectoryRef>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="ProgramFilesComponents">
      <ComponentRef Id="AgentExeComponent" />
      <ComponentRef Id="DefaultConfigComponent" />
    </ComponentGroup>
    <ComponentGroup Id="ProgramDataComponents">
      <ComponentRef Id="ProgramDataDirComponent" />
    </ComponentGroup>
  </Fragment>
</Include>
